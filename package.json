{
  "name": "hdd-ui-lib",
  "version": "0.0.1",
  "description": "A Vue3 Component Library",
  "keywords": [
    "vue",
    "vue3",
    "component",
    "ui",
    "library"
  ],
  "author": "huangdd",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/hdd-ui-lib.umd.js",
  "module": "./dist/hdd-ui-lib.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/hdd-ui-lib.es.js",
      "require": "./dist/hdd-ui-lib.umd.js"
    },
    "./dist/hdd-ui-lib.css": "./dist/hdd-ui-lib.css"
  },
  "scripts": {
    "dev": "vite --config playground/vite.config.ts playground",
    "build": "vite build",
    "preview": "vite preview",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "dependencies": {
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "typescript": "^5.5.0",
    "vite": "^8.0.12",
    "vitepress": "^1.5.0",
    "vue-tsc": "^2.0.0"
  }
}
